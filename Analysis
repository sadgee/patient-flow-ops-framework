      "source": [
        "from sklearn.compose import ColumnTransformer\n",
        "from sklearn.ensemble import GradientBoostingClassifier\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import roc_auc_score, brier_score_loss\n",
        "from sklearn.model_selection import GroupShuffleSplit\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.preprocessing import StandardScaler, OneHotEncoder\n",
        "\n",
        "df = kaggle.sort_values([\"PatientId\", \"ScheduledDay\"]).reset_index(drop=True)\n",
        "df[\"AppointmentDow\"] = df[\"AppointmentDay\"].dt.dayofweek\n",
        "df[\"AgeGroup\"] = pd.cut(df[\"Age\"], bins=[-1, 5, 17, 39, 64, 200],\n",
        "                          labels=[\"0-5\", \"6-17\", \"18-39\", \"40-64\", \"65+\"])\n",
        "df[\"AnyChronic\"] = ((df[\"Hypertension\"] + df[\"Diabetes\"] + df[\"Alcoholism\"] +\n",
        "                       (df[\"Handicap\"] > 0)) > 0).astype(int)\n",
        "df[\"LeadBucket\"] = pd.cut(df[\"LeadDays\"], bins=[-1, 0, 2, 7, 30, 1000],\n",
        "                            labels=[\"same_day\", \"1-2d\", \"3-7d\", \"8-30d\", \"31d+\"])\n",
        "df[\"prior_appts\"] = df.groupby(\"PatientId\").cumcount()\n",
        "df[\"prior_noshows\"] = df.groupby(\"PatientId\")[\"NoShow\"].cumsum() - df[\"NoShow\"]\n",
        "df[\"prior_noshow_rate\"] = np.where(df[\"prior_appts\"] > 0,\n",
        "                                     df[\"prior_noshows\"] / df[\"prior_appts\"], 0.0)\n",
        "\n",
        "FEATURES_NUM = [\"Age\", \"LeadDays\", \"SMS_received\", \"Scholarship\",\n",
        "                \"Hypertension\", \"Diabetes\", \"Alcoholism\", \"Handicap\",\n",
        "                \"AnyChronic\", \"prior_appts\", \"prior_noshow_rate\"]\n",
        "FEATURES_CAT = [\"Gender\", \"AgeGroup\", \"LeadBucket\", \"AppointmentDow\"]\n",
        "\n",
        "X = df[FEATURES_NUM + FEATURES_CAT]\n",
        "y = df[\"NoShow\"]\n",
        "\n",
        "gss = GroupShuffleSplit(n_splits=1, test_size=0.25, random_state=0)\n",
        "train_idx, test_idx = next(gss.split(X, y, groups=df[\"PatientId\"]))\n",
        "X_tr, X_te = X.iloc[train_idx], X.iloc[test_idx]\n",
        "y_tr, y_te = y.iloc[train_idx], y.iloc[test_idx]\n",
        "overlap = set(df.iloc[train_idx][\"PatientId\"]) & set(df.iloc[test_idx][\"PatientId\"])\n",
        "assert not overlap, f\"Patient leakage: {len(overlap)}\"\n",
        "print(f\"Train: {len(X_tr):,} appts ({df.iloc[train_idx]['PatientId'].nunique():,} patients)\")\n",
        "print(f\"Test:  {len(X_te):,} appts ({df.iloc[test_idx]['PatientId'].nunique():,} patients)\")\n",
        "print(f\"Patient overlap: {len(overlap)} (expected 0)\")\n",
        "\n",
        "pre = ColumnTransformer([\n",
        "    (\"num\", StandardScaler(), FEATURES_NUM),\n",
        "    (\"cat\", OneHotEncoder(drop=\"first\", handle_unknown=\"ignore\"), FEATURES_CAT),\n",
        "])\n",
        "gbm = Pipeline([(\"pre\", pre),\n",
        "                 (\"clf\", GradientBoostingClassifier(n_estimators=200, max_depth=3,\n",
        "                                                       learning_rate=0.05, random_state=0))])\n",
        "gbm.fit(X_tr, y_tr)\n",
        "p_gbm = gbm.predict_proba(X_te)[:, 1]\n",
        "auc_gbm = roc_auc_score(y_te, p_gbm)\n",
        "\n",
        "logit = Pipeline([(\"pre\", pre),\n",
        "                   (\"clf\", LogisticRegression(max_iter=1000, random_state=0))]).fit(X_tr, y_tr)\n",
        "auc_logit = roc_auc_score(y_te, logit.predict_proba(X_te)[:, 1])\n",
        "\n",
        "print(f\"\\nTest AUC: GBM = {auc_gbm:.3f} · logit = {auc_logit:.3f} · \"\n",
        "      f\"base rate = {y.mean():.3f}\")\n",
        "print(f\"Brier score (GBM): {brier_score_loss(y_te, p_gbm):.4f}\")\n",
        "\n",
        "joblib.dump(gbm, OUT / \"noshow_model.joblib\")\n"
      ]
    },
