        "def run_grid(providers, patients, st_base, base_sched,\n",
        "              noshow_target, md_mult, n_nurses, n_reps=15, seed=200):\n",
        "    sched = base_sched.copy()\n",
        "    raw_mean = sched[\"p_noshow\"].mean()\n",
        "    if raw_mean > 0:\n",
        "        sched[\"p_noshow\"] = (sched[\"p_noshow\"] * (noshow_target/raw_mean)).clip(0.01, 0.95)\n",
        "    st = json.loads(json.dumps(st_base))\n",
        "    for k in (\"md_speccat_1\",\"md_speccat_2\",\"md_speccat_3\"):\n",
        "        new_mean = st[k][\"mean\"] * md_mult\n",
        "        sigma = st[k][\"sigma\"]\n",
        "        st[k][\"mu\"] = float(np.log(new_mean) - sigma**2/2)\n",
        "        st[k][\"mean\"] = float(new_mean)\n",
        "    rows = []\n",
        "    for rep in range(n_reps):\n",
        "        cfg = SimConfig(seed=seed+rep, n_nurses=n_nurses)\n",
        "        sim = ClinicSim(providers, sched, st, cfg, \"sens\")\n",
        "        v = sim.run(); c = v[~v[\"no_show\"]]\n",
        "        rows.append({\"noshow_target\": noshow_target, \"md_time_mult\": md_mult,\n",
        "                       \"n_nurses\": n_nurses, \"rep\": rep,\n",
        "                       \"throughput\": len(c),\n",
        "                       \"median_wait_min\": c[\"wait_to_md\"].median()})\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "rng_s = np.random.default_rng(0)\n",
        "sens_base = attach_noshow_probs(\n",
        "    build_schedule(providers, patients, SimConfig(seed=0), rng_s),\n",
        "    patients, gbm, rng_s)\n",
        "\n",
        "grid = []\n",
        "for ns in [0.10, 0.15, 0.18, 0.22, 0.25, 0.30]:\n",
        "    grid.append(run_grid(providers, patients, service_times, sens_base, ns, 1.0, 6))\n",
        "for mt in [0.85, 1.0, 1.15, 1.30]:\n",
        "    grid.append(run_grid(providers, patients, service_times, sens_base, 0.18, mt, 6))\n",
        "for nu in [4, 5, 6, 7, 8, 10]:\n",
        "    grid.append(run_grid(providers, patients, service_times, sens_base, 0.18, 1.0, nu))\n",
