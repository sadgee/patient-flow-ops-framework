        "              alpha=0.7, edgecolor=\"white\")\n",
        "    xs = np.linspace(1, 90, 200)\n",
        "    pdf = stats.lognorm.pdf(xs, s=shape, scale=scale)\n",
        "    ax.plot(xs, pdf, \"r-\", lw=2, label=f\"Lognormal fit\\nmedian={scale:.1f} min\")\n",
        "    ax.set_title(f\"{label} (n={len(x):,})\")\n",
        "    ax.set_xlabel(\"Minutes with physician (TIMEMD)\")\n",
