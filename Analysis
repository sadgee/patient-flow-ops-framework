        "class ClinicSim:\n",
        "    def __init__(self, providers, schedule, service_times, cfg, policy=\"baseline\"):\n",
        "        self.providers = providers.set_index(\"provider_id\")\n",
        "        self.schedule = schedule.copy()\n",
        "        self.service_times = service_times\n",
        "        self.cfg = cfg; self.policy = policy\n",
        "        self.rng = np.random.default_rng(cfg.seed)\n",
        "        self.records = []\n",
        "        self.env = simpy.Environment()\n",
        "        self.checkin = simpy.Resource(self.env, capacity=cfg.n_checkin)\n",
        "        self.nurses = simpy.Resource(self.env, capacity=cfg.n_nurses)\n",
        "        self.mds = {pid: simpy.Resource(self.env, capacity=1)\n",
        "                     for pid in self.providers.index}\n",
        "        self.md_busy_min = {pid: 0.0 for pid in self.providers.index}\n",
        "        self.checkin_busy_min = 0.0\n",
        "        self.nurse_busy_min = 0.0\n",
        "\n",
        "    def _md_time(self, sc):\n",
        "        p = self.service_times[f\"md_speccat_{sc}\"]\n",
        "        return lognormal_sample(self.rng, p[\"mu\"], p[\"sigma\"])\n",
        "    def _ci_time(self):\n",
        "        p = self.service_times[\"checkin\"]\n",
        "        return lognormal_sample(self.rng, p[\"mu\"], p[\"sigma\"])\n",
        "    def _n_time(self):\n",
        "        p = self.service_times[\"nurse_intake\"]\n",
        "        return lognormal_sample(self.rng, p[\"mu\"], p[\"sigma\"])\n",
        "\n",
        "    def patient_process(self, rec):\n",
        "        if rec.no_show: return\n",
        "        arrival = max(0.0, rec.scheduled_min +\n",
        "                       self.rng.normal(0, self.cfg.arrival_jitter_sd_min))\n",
        "        if self.env.now < arrival:\n",
        "            yield self.env.timeout(arrival - self.env.now)\n",
        "        rec.arrived_min = self.env.now\n",
        "        with self.checkin.request() as r:\n",
        "            yield r\n",
        "            rec.checkin_start = self.env.now\n",
        "            d = self._ci_time(); yield self.env.timeout(d)\n",
        "            rec.checkin_end = self.env.now; self.checkin_busy_min += d\n",
        "        with self.nurses.request() as r:\n",
        "            yield r\n",
        "            rec.nurse_start = self.env.now\n",
        "            d = self._n_time(); yield self.env.timeout(d)\n",
        "            rec.nurse_end = self.env.now; self.nurse_busy_min += d\n",
        "        with self.mds[rec.provider_id].request() as r:\n",
        "            yield r\n",
        "            rec.md_start = self.env.now\n",
        "            d = self._md_time(rec.speccat); yield self.env.timeout(d)\n",
        "            rec.md_end = self.env.now; self.md_busy_min[rec.provider_id] += d\n",
        "\n",
        "    def run(self):\n",
        "        ns = self.rng.random(len(self.schedule))\n",
        "        for i, (_, row) in enumerate(self.schedule.iterrows()):\n",
        "            rec = VisitRecord(\n",
        "                patient_id=row[\"patient_id\"], provider_id=row[\"provider_id\"],\n",
        "                speccat=int(row[\"speccat\"]),\n",
        "                patient_network=str(row.get(\"patient_network\", \"?\")),\n",
        "                patient_payer=str(row.get(\"patient_payer\", \"?\")),\n",
        "                scheduled_min=float(row[\"scheduled_min\"]),\n",
        "                arrived_min=None, no_show=bool(ns[i] < row[\"p_noshow\"]),\n",
        "            )\n",
        "            self.records.append(rec)\n",
        "            self.env.process(self.patient_process(rec))\n",
        "        self.env.run(until=CLINIC_CLOSE_MIN + 240)\n",
        "        return pd.DataFrame([{\n",
        "            \"patient_id\": r.patient_id, \"provider_id\": r.provider_id,\n",
        "            \"speccat\": r.speccat,\n",
        "            \"patient_network\": r.patient_network, \"patient_payer\": r.patient_payer,\n",
        "            \"scheduled_min\": r.scheduled_min, \"no_show\": r.no_show,\n",
        "            \"arrived_min\": r.arrived_min, \"wait_to_md\": r.wait_to_md(),\n",
        "            \"wait_for_checkin\": r.wait_for_checkin(),\n",
        "            \"wait_for_nurse\": r.wait_for_nurse(),\n",
        "            \"wait_for_md\": r.wait_for_md(),\n",
        "            \"md_start\": r.md_start, \"md_end\": r.md_end,\n",
        "        } for r in self.records])\n",
        "\n",
        "\n",
        "def run_replications(providers, patients, schedule, service_times, cfg,\n",
        "                       policy=\"baseline\", n_reps=10):\n",
        "    rows = []\n",
        "    for rep in range(n_reps):\n",
        "        rep_cfg = SimConfig(**{**cfg.__dict__, \"seed\": cfg.seed + rep})\n",
        "        sim = ClinicSim(providers, schedule, service_times, rep_cfg, policy)\n",
        "        v = sim.run()\n",
        "        c = v[~v[\"no_show\"]]\n",
        "        rows.append({\"rep\": rep, \"policy\": policy,\n",
        "                       \"n_completed\": len(c), \"no_show_rate\": v[\"no_show\"].mean(),\n",
        "                       \"median_wait_min\": c[\"wait_to_md\"].median(),\n",
        "                       \"p90_wait_min\": c[\"wait_to_md\"].quantile(0.90),\n",
        "                       \"mean_md_util\": float(np.mean([min(1.0, sim.md_busy_min[p]/480)\n",
        "                                                          for p in sim.md_busy_min])),\n",
        "                       \"nurse_util_capped\": min(1.0, sim.nurse_busy_min/(rep_cfg.n_nurses*480)),\n",
        "                       \"nurse_busy_min\": sim.nurse_busy_min,\n",
        "                       \"throughput\": len(c)})\n",
        "    return pd.DataFrame(rows)\n",
        "\n",
        "\n",
        "# Build base schedule + apply rescaled p(no-show)\n",
        "cfg = SimConfig(seed=0)\n",
        "rng = np.random.default_rng(cfg.seed)\n",
        "base_schedule = build_schedule(providers, patients, cfg, rng)\n",
        "base_schedule = attach_noshow_probs(base_schedule, patients, gbm, rng)\n",
        "base_schedule.to_parquet(OUT / \"schedule_with_p.parquet\")\n",
        "print(f\"Base schedule: {len(base_schedule)} appointments · \"\n",
        "      f\"mean p(no-show) = {base_schedule['p_noshow'].mean():.3f} (target {US_BASE_NOSHOW})\")\n",
        "\n",
        "# Baseline (10 reps)\n",
        "baseline_summary = run_replications(providers, patients, base_schedule,\n",
        "                                       service_times, cfg, \"baseline\", n_reps=10)\n",
        "print(\"\\nBaseline (10 reps):\")\n",
        "print(baseline_summary[[\"n_completed\",\"no_show_rate\",\"median_wait_min\",\n",
        "                          \"p90_wait_min\",\"mean_md_util\",\"nurse_util_capped\"]].describe().round(2))\n"
      ]
