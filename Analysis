        "P_THRESH = 0.30\n",
        "\n",
        "def policy_baseline(schedule, providers, patients, rng):\n",
        "    return schedule.copy()\n",
        "\n",
        "def policy_nar(schedule, providers, patients, rng):\n",
        "    high_risk = schedule[schedule[\"p_noshow\"] > P_THRESH]\n",
        "    used = set(schedule[\"patient_id\"])\n",
        "    free = patients[~patients[\"patient_id\"].isin(used)].copy()\n",
        "    pool_by_key = {k: list(v) for k, v in\n",
        "                     free.groupby([\"network\", \"speccat_needed\"]).indices.items()}\n",
        "    for k in pool_by_key: rng.shuffle(pool_by_key[k])\n",
        "    cursor = {k: 0 for k in pool_by_key}\n",
        "    extras = []\n",
        "    prov_nets = providers.set_index(\"provider_id\")[\"networks\"].to_dict()\n",
        "    for _, row in high_risk.iterrows():\n",
        "        prov_net_set = set(prov_nets[row[\"provider_id\"]].split(\"|\"))\n",
        "        chosen = None\n",
        "        for net in prov_net_set:\n",
        "            key = (net, int(row[\"speccat\"]))\n",
        "            if key in cursor and cursor[key] < len(pool_by_key[key]):\n",
        "                pat_idx = pool_by_key[key][cursor[key]]\n",
        "                cursor[key] += 1\n",
        "                chosen = patients.loc[pat_idx]; break\n",
        "        if chosen is None: continue\n",
        "        extras.append({\"patient_id\": chosen[\"patient_id\"],\n",
        "                         \"provider_id\": row[\"provider_id\"],\n",
        "                         \"speccat\": row[\"speccat\"],\n",
        "                         \"patient_payer\": chosen[\"payer\"],\n",
        "                         \"patient_network\": chosen[\"network\"],\n",
        "                         \"scheduled_min\": row[\"scheduled_min\"],\n",
        "                         \"p_noshow\": 0.05})\n",
        "    if not extras: return schedule.copy()\n",
        "    return pd.concat([schedule, pd.DataFrame(extras)], ignore_index=True)\n",
        "\n",
        "def policy_rbs(schedule, providers, patients, rng):\n",
        "    s = schedule.sort_values([\"provider_id\",\"scheduled_min\"]).reset_index(drop=True)\n",
        "    drop = set()\n",
        "    for prov_id, group in s.groupby(\"provider_id\"):\n",
        "        idx = group.sort_values(\"scheduled_min\").index.tolist()\n",
        "        for i in range(len(idx)-1):\n",
        "            this_idx, next_idx = idx[i], idx[i+1]\n",
        "            if s.loc[this_idx, \"p_noshow\"] > P_THRESH and this_idx not in drop:\n",
        "                drop.add(next_idx)\n",
        "    return s.drop(index=list(drop)).reset_index(drop=True)\n",
        "\n",
        "\n",
        "def overtime_hours(busy_min, n_servers, open_min=480):\n",
        "    capacity_min = n_servers * open_min\n",
        "    return max(0, (busy_min - capacity_min) / n_servers / 60)\n",
        "\n",
        "\n",
        "POLICIES = {\"baseline\": policy_baseline,\n",
        "              \"NAR (reassign no-show slots)\": policy_nar,\n",
        "              \"RBS (risk-buffered schedule)\": policy_rbs}\n",
        "\n",
        "cfg = SimConfig(seed=100)\n",
        "rng = np.random.default_rng(cfg.seed)\n",
        "base_schedule_p = attach_noshow_probs(\n",
        "    build_schedule(providers, patients, cfg, rng), patients, gbm, rng)\n",
        "print(f\"Schedule: {len(base_schedule_p)} appts · \"\n",
        "      f\"{(base_schedule_p['p_noshow']>P_THRESH).sum()} flagged high-risk\")\n",
        "\n",
        "all_results, all_visits = [], []\n",
        "for name, fn in POLICIES.items():\n",
        "    rep_rows, vis_rows = [], []\n",
        "    for rep in range(30):\n",
        "        rng_rep = np.random.default_rng(cfg.seed + rep)\n",
        "        sched = fn(base_schedule_p, providers, patients, rng_rep)\n",
        "        rep_cfg = SimConfig(**{**cfg.__dict__, \"seed\": cfg.seed + rep})\n",
        "        sim = ClinicSim(providers, sched, service_times, rep_cfg, name)\n",
        "        v = sim.run(); c = v[~v[\"no_show\"]]\n",
        "        rep_rows.append({\"rep\": rep, \"policy\": name,\n",
        "                           \"throughput\": len(c),\n",
        "                           \"median_wait_min\": c[\"wait_to_md\"].median(),\n",
        "                           \"p90_wait_min\": c[\"wait_to_md\"].quantile(0.90),\n",
        "                           \"mean_wait_checkin\": c[\"wait_for_checkin\"].mean(),\n",
        "                           \"mean_wait_nurse\": c[\"wait_for_nurse\"].mean(),\n",
        "                           \"mean_wait_md_only\": c[\"wait_for_md\"].mean(),\n",
        "                           \"no_show_rate\": v[\"no_show\"].mean(),\n",
        "                           \"mean_md_util\": float(np.mean([min(1.0, sim.md_busy_min[p]/480)\n",
        "                                                              for p in sim.md_busy_min])),\n",
        "                           \"nurse_overtime_hrs\": overtime_hours(sim.nurse_busy_min, rep_cfg.n_nurses)})\n",
        "        c2 = c.copy(); c2[\"policy\"]=name; c2[\"rep\"]=rep\n",
        "        vis_rows.append(c2[[\"policy\",\"rep\",\"patient_payer\",\"patient_network\",\n",
        "                              \"speccat\",\"wait_for_checkin\",\"wait_for_nurse\",\n",
        "                              \"wait_for_md\",\"wait_to_md\"]])\n",
        "    df_r = pd.DataFrame(rep_rows)\n",
        "    print(f\"  {name}: throughput={df_r['throughput'].mean():.0f} · \"\n",
        "          f\"wait={df_r['median_wait_min'].mean():.1f} min · \"\n",
        "          f\"OT={df_r['nurse_overtime_hrs'].mean():.2f} hr\")\n",
        "    all_results.append(df_r)\n",
        "    all_visits.append(pd.concat(vis_rows, ignore_index=True))\n",
        "results = pd.concat(all_results, ignore_index=True)\n",
        "visits = pd.concat(all_visits, ignore_index=True)\n",
        "results.to_parquet(OUT / \"scenario_results.parquet\")\n",
        "visits.to_parquet(OUT / \"scenario_visits.parquet\")\n"
      ]
    },
